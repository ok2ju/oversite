# Oversite Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Faceit OAuth (required) ──────────────────────────────────
# Register an app at https://developers.faceit.com to get these.
FACEIT_CLIENT_ID=
FACEIT_CLIENT_SECRET=
FACEIT_REDIRECT_URI=https://localhost/api/v1/auth/faceit/callback
FACEIT_API_KEY=

# ── Database ─────────────────────────────────────────────────
# Defaults work with the Docker Compose postgres service.
# DATABASE_URL=postgres://oversite:oversite@postgres:5432/oversite?sslmode=disable

# ── Redis ────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379

# ── MinIO (S3-compatible object storage) ─────────────────────
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_USE_SSL=false
# MINIO_BUCKET=demos
